{
  "name": "vitest-auto-spy",
  "version": "1.0.0",
  "description": "Auto-spy utilities for Vitest + Angular (works with both zoneless and zone.js). Drop-in replacement for jest-auto-spies.",
  "keywords": [
    "vitest",
    "angular",
    "testing",
    "unit-testing",
    "spy",
    "spies",
    "mock",
    "mocking",
    "test-doubles",
    "auto-spy",
    "auto-spies",
    "jest-auto-spies",
    "rxjs",
    "observable",
    "zoneless",
    "typescript"
  ],
  "license": "MIT",
  "author": "Alexey Popov <asdalexey@yandex.ru>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ASDAlexey/vitest-auto-spy.git"
  },
  "homepage": "https://github.com/ASDAlexey/vitest-auto-spy#readme",
  "bugs": {
    "url": "https://github.com/ASDAlexey/vitest-auto-spy/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "rxjs": ">=7.0.0",
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.0",
    "@analogjs/vitest-angular": "^2.2.0",
    "@angular/build": "^21.2.16",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/compiler-cli": "^21.2.17",
    "@angular/core": "^21.0.0",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "rxjs": "^7.8.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "javascript-stringify": "^2.1.0"
  }
}
